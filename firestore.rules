rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================================
    // HELPER FUNCTIONS & AUTHENTICATION CONTEXT
    // =========================================================================

    function isSignedIn() {
      return request.auth != null;
    }

    // 1. Admin Role: Verified via admin email address
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'harebsalman@gmail.com' ||
        request.auth.token.email == 'admin@royalgroup.com'
      );
    }

    function getUserEmail() {
      return isSignedIn() && request.auth.token.email != null ? request.auth.token.email : '';
    }

    function getUserPhone() {
      return isSignedIn() && request.auth.token.phone_number != null ? request.auth.token.phone_number : '';
    }

    function getUserId() {
      return isSignedIn() ? request.auth.uid : '';
    }

    // 2. Engineer Authorization Check
    function isAssignedEngineer(ticketData) {
      return isSignedIn() && (
        (ticketData.assignedEngineerId != null && ticketData.assignedEngineerId == getUserId()) ||
        (ticketData.assignedEngineerEmail != null && ticketData.assignedEngineerEmail == getUserEmail())
      );
    }

    // 3. Client Ownership Authorization Check
    function isTicketClientOwner(ticketData) {
      return isSignedIn() && (
        (ticketData.clientId != null && ticketData.clientId == getUserId()) ||
        (ticketData.clientPhone != null && getUserPhone() != '' && ticketData.clientPhone == getUserPhone())
      );
    }

    // 4. Combined Ticket Access Validator
    function canAccessTicket(ticketData) {
      return isAdmin() || isAssignedEngineer(ticketData) || isTicketClientOwner(ticketData);
    }

    // Cross-collection ticket lookup for message authorization
    function getTicketData(ticketId) {
      return get(/databases/$(database)/documents/tickets/$(ticketId)).data;
    }

    function ticketExists(ticketId) {
      return exists(/databases/$(database)/documents/tickets/$(ticketId));
    }


    // =========================================================================
    // PUBLIC SHOWCASE & CATALOG COLLECTIONS (READ: PUBLIC, WRITE: ADMIN ONLY)
    // Justified: Public website catalog viewing
    // =========================================================================

    match /projects/{projectId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /projectImages/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /colorVariants/{variantId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /bedroomOptions/{optionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /companySettings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /socialLinks/{linkId} {
      allow read: if true;
      allow write: if isAdmin();
    }


    // =========================================================================
    // CLIENT REQUEST COLLECTIONS
    // =========================================================================

    match /designRequests/{requestId} {
      allow create: if true; // Public submission form
      allow get: if isAdmin() || (isSignedIn() && resource.data.phone == getUserPhone());
      allow list: if isAdmin() || (isSignedIn() && resource.data.phone == getUserPhone());
      allow update, delete: if isAdmin();
    }

    match /bedroomSubmissions/{submissionId} {
      allow create: if true; // Public submission form
      allow get: if isAdmin() || (isSignedIn() && resource.data.clientPhone == getUserPhone());
      allow list: if isAdmin() || (isSignedIn() && resource.data.clientPhone == getUserPhone());
      allow update, delete: if isAdmin();
    }


    // =========================================================================
    // ENGINEERS COLLECTION
    // =========================================================================

    match /engineers/{engineerId} {
      // Admin reads/manages all engineers.
      // Individual engineers read only their own profile document.
      // Clients are STRICTLY BLOCKED from reading engineer directory documents.
      allow read: if isAdmin() || (isSignedIn() && (resource.data.email == getUserEmail() || engineerId == getUserId()));
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        isSignedIn() && 
        (resource.data.email == getUserEmail() || engineerId == getUserId()) &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['email', 'role'])
      );
    }


    // =========================================================================
    // TICKETS COLLECTION
    // =========================================================================

    match /tickets/{ticketId} {
      // Read: Admin reads all. Engineer reads assigned tickets only. Client reads their own tickets only.
      allow read: if canAccessTicket(resource.data);

      // Create: Admin or authenticated client creating their own ticket
      allow create: if isAdmin() || (
        isSignedIn() && 
        (request.resource.data.clientPhone == getUserPhone() || request.resource.data.clientId == getUserId())
      );

      // Update:
      // - Admin: Full update privileges (status, engineer assignment, content).
      // - Engineer: CANNOT change status (close/reopen) or reassign engineer.
      // - Client: CANNOT alter status, assign engineers, or modify core ticket fields.
      allow update: if isAdmin() || (
        isAssignedEngineer(resource.data) &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'assignedEngineerId', 'assignedEngineerEmail', 'assignedEngineerName'])
      );

      // Delete: Admin only
      allow delete: if isAdmin();
    }


    // =========================================================================
    // MESSAGES COLLECTION (CHAT ROOM SECURITY)
    // =========================================================================

    match /messages/{messageId} {
      // Read: Allowed ONLY if user is authorized to view the parent ticket.
      allow read: if isAdmin() || (
        isSignedIn() && 
        ticketExists(resource.data.ticketId) && 
        canAccessTicket(getTicketData(resource.data.ticketId))
      );

      // Create: Allowed ONLY if user belongs to the ticket AND sets their own senderId.
      allow create: if isAdmin() || (
        isSignedIn() && 
        ticketExists(request.resource.data.ticketId) && 
        canAccessTicket(getTicketData(request.resource.data.ticketId)) &&
        request.resource.data.senderId == getUserId()
      );

      // Update: Admin, or participants marking read status
      allow update: if isAdmin() || (
        isSignedIn() && 
        ticketExists(resource.data.ticketId) && 
        canAccessTicket(getTicketData(resource.data.ticketId)) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'readAt'])
      );

      allow delete: if isAdmin();
    }


    // =========================================================================
    // NOTIFICATIONS COLLECTION
    // =========================================================================

    match /notifications/{notifId} {
      allow read: if isAdmin() || (
        isSignedIn() && (
          resource.data.recipientId == getUserId() ||
          resource.data.recipientEmail == getUserEmail() ||
          resource.data.recipientPhone == getUserPhone()
        )
      );

      allow create: if isSignedIn();

      allow update: if isAdmin() || (
        isSignedIn() && (
          resource.data.recipientId == getUserId() ||
          resource.data.recipientEmail == getUserEmail() ||
          resource.data.recipientPhone == getUserPhone()
        ) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'readAt'])
      );

      allow delete: if isAdmin();
    }


    // =========================================================================
    // COUNTERS COLLECTION
    // =========================================================================

    match /counters/{counterId} {
      allow read, write: if isSignedIn();
    }
  }
}