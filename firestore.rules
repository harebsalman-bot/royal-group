rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    // Verify if the logged-in user is the official Royal Group Administrator
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'harebsalman@gmail.com';
    }

    // Helper function to validate project schema
    function isValidProject(data) {
      return data.keys().hasAll(['id', 'title', 'description', 'area', 'city', 'coverImage', 'category', 'featured', 'createdAt'])
        && data.id is string
        && data.title is string
        && data.description is string
        && data.area is string
        && data.city is string
        && data.coverImage is string
        && data.category is string
        && data.featured is bool
        && data.createdAt is int
        && (!('beforeImage' in data) || data.beforeImage is string)
        && (!('afterImage' in data) || data.afterImage is string)
        && (!('images' in data) || data.images is list)
        && (!('orderIndex' in data) || data.orderIndex is int);
    }

    // PROJECTS Collection
    match /projects/{projectId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidProject(request.resource.data);
      allow delete: if isAdmin();
    }

    // CATEGORIES Collection
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // PROJECT IMAGES Collection
    match /projectImages/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // COLOR VARIANTS Collection
    match /colorVariants/{variantId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // COMPANY SETTINGS Collection
    match /companySettings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // SOCIAL LINKS Collection
    match /socialLinks/{linkId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // BEDROOM OPTIONS Collection
    match /bedroomOptions/{optionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // DESIGN REQUESTS Collection
    match /designRequests/{requestId} {
      allow create: if true;
      allow get: if true;
      allow list: if isAdmin() || (request.query.limit <= 20);
      allow update, delete: if isAdmin();
    }

    // BEDROOM SUBMISSIONS Collection
    match /bedroomSubmissions/{submissionId} {
      allow create: if true;
      allow get: if true;
      allow list: if isAdmin() || (request.query.limit <= 20);
      allow update, delete: if isAdmin();
    }

    // ENGINEERS Collection (Kept for backward compatibility but deprecated)
    match /engineers/{engineerId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['currentTickets']));
    }

    // USERS Collection (Unified Single Source of Truth for Users & Engineers)
    match /users/{userId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['currentTickets', 'currentProjects']));
    }

    // TICKETS Collection
    match /tickets/{ticketId} {
      allow create: if true;
      allow read: if true; // Clients access single tickets by ID; engineers access assigned ones
      allow update: if true;
      allow delete: if isAdmin();
    }

    // MESSAGES Collection
    match /messages/{messageId} {
      allow read, write: if true;
    }

    // NOTIFICATIONS Collection
    match /notifications/{notifId} {
      allow read, write: if true;
    }

    // COUNTERS Collection
    match /counters/{counterId} {
      allow read, write: if true;
    }
  }
}
