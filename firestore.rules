rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    // Verify if the logged-in user is the official Royal Group Administrator
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'harebsalman@gmail.com';
    }

    // PROJECTS Collection
    match /projects/{projectId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // CATEGORIES Collection
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // PROJECT IMAGES Collection
    match /projectImages/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // COLOR VARIANTS Collection
    match /colorVariants/{variantId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // COMPANY SETTINGS Collection
    match /companySettings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // SOCIAL LINKS Collection
    match /socialLinks/{linkId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // BEDROOM OPTIONS Collection
    match /bedroomOptions/{optionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // DESIGN REQUESTS Collection
    match /designRequests/{requestId} {
      allow create: if true;
      allow get: if true;
      allow list: if isAdmin() || (request.query.limit <= 20);
      allow update, delete: if isAdmin();
    }

    // BEDROOM SUBMISSIONS Collection
    match /bedroomSubmissions/{submissionId} {
      allow create: if true;
      allow get: if true;
      allow list: if isAdmin() || (request.query.limit <= 20);
      allow update, delete: if isAdmin();
    }

    // COUNTERS Collection
    match /counters/{counterId} {
      allow read, write: if true;
    }
  }
}
